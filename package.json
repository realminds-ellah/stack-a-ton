{
  "name": "gets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GETS — Guided Education for Tailored Success. Bilingual (Tagalog + English) AI study companion for Grade 7 Filipino students, aligned to DepEd MATATAG.",
  "scripts": {
    "dev": "concurrently -n client,api -c cyan,magenta \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node server/index.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "seed": "node scripts/preseed.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^5.4.11"
  }
}
