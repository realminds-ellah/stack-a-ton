# ── GETS AI config ───────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your key. .env.local is git-ignored;
# NEVER commit a real key, and never prefix the key with VITE_ (that would expose
# it to the browser). The key stays server-side (Vite dev proxy / serverless fn).

# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — defaults to gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Where the frontend sends generation requests (defaults to /api/generate).
VITE_AI_ENDPOINT=/api/generate

# ── Text-to-Speech (Read Aloud voice) — uses the same GEMINI_API_KEY ────────────
# Optional — defaults shown. Voices: Aoede (warm), Kore, Puck, Charon, Leda, etc.
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Aoede
VITE_TTS_ENDPOINT=/api/tts
