# Copy this file to ".env" and add a key for ONE provider.
# Never commit your real .env — it is gitignored.

# Which provider: gemini (free, best Tagalog) | groq (free, fastest) | anthropic (Claude).
# If unset, auto-picks gemini → groq → anthropic by whichever key is present.
GETS_PROVIDER=gemini

# Gemini — FREE key at https://aistudio.google.com/apikey (no card needed)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Groq — free key at https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (Claude) — key at https://console.anthropic.com/settings/keys
# (pay-as-you-go; needs credit under Plans & Billing)
ANTHROPIC_API_KEY=sk-ant-...
# GETS_MODEL=claude-haiku-4-5

# PORT=8787
