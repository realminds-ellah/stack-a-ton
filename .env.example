# Copy this file to ".env" and paste your Anthropic API key.
# Never commit your real .env — it is gitignored.

# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides:
# Model used for live generation + pre-seeding. Haiku 4.5 is fast and cheap;
# swap to claude-sonnet-4-6 for richer output.
# GETS_MODEL=claude-haiku-4-5
# Port for the local generation proxy (Vite proxies /api here).
# PORT=8787
